POSTGRES_PASSWORD=change_me

# Copy this file to .env and set a secure password before running docker-compose
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Leave empty in local development so the browser uses Vite's same-origin proxy.
VITE_API_BASE_URL=
VITE_API_PROXY_TARGET=http://127.0.0.1:8000

# Limits simultaneous Chromium processes per API worker.
MAX_CONCURRENT_SCRAPES=3
